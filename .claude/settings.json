{
  "permissions": {
    "allow": [
      "Bash(mkdir **)",
      "Bash(uv run pytest *)",
      "Bash(uv sync *)",
      "Bash(uv add *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(gh pr view *)",
      "Edit(*.py)",
      "Edit(*.md)",
      "Edit(*.sh)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  }
}